-- --------------------------------------------------------
-- Table Structure for 'app_enquiries'
-- Target Engine Compatibility: SQLite3 / PostgreSQL / MySQL
-- --------------------------------------------------------

CREATE TABLE IF NOT EXISTS "app_enquiries" (
    "id" integer NOT NULL PRIMARY KEY AUTOINCREMENT,
    "name" varchar(100) NOT NULL,
    "email" varchar(254) NOT NULL,
    "subject" varchar(200) NOT NULL,
    "message" text NOT NULL,
    "status" varchar(20) NOT NULL DEFAULT 'Pending',
    "created_at" datetime NOT NULL
);

-- --------------------------------------------------------
-- Performance Index Optimization
-- Speeds up search queries when filtering records by status or date
-- --------------------------------------------------------
CREATE INDEX IF NOT EXISTS "app_enquiries_status_idx" 
ON "app_enquiries" ("status");

CREATE INDEX IF NOT EXISTS "app_enquiries_created_at_idx" 
ON "app_enquiries" ("created_at");

    def __str__(self):
        return f"[{self.status}] {self.name} - {self.subject}"






