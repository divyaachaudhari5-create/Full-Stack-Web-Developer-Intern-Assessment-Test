from django.db import models

class Enquiry(models.Model):
    # Enforces discrete state machine tracking for system enquiries
    STATUS_CHOICES = [
        ('Pending', 'Pending'),
        ('Resolved', 'Resolved'),
    ]

    # PRIMARY KEY (auto-created by Django as: id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT)
    
    # Structural Attributes & Constraints
    name = models.CharField(
        max_length=100, 
        help_text="The full identity name of the contact sender."
    )
    email = models.EmailField(
        max_length=254, 
        help_text="Validated electronic communication address."
    )
    subject = models.CharField(
        max_length=200, 
        help_text="Categorized header subject of the message query."
    )
    message = models.TextField(
        help_text="Unbounded plain-text transactional message content body."
    )
    status = models.CharField(
        max_length=20, 
        choices=STATUS_CHOICES, 
        default='Pending',
        help_text="Workflow execution status mapping tracking flag."
    )
    created_at = models.DateTimeField(
        auto_now_add=True, 
        help_text="Automated database-level timestamp generated upon row insert."
    )

    class Meta:
        db_table = 'app_enquiries'  # Explicitly custom named database table
        verbose_name = 'Customer Enquiry'
        verbose_name_plural = 'Customer Enquiries'





