from rest_framework import status, serializers, viewsets
from rest_framework.response import Response
from rest_framework.permissions import IsAuthenticatedOrReadOnly
from .models import Enquiry

# ==========================================
# 1. REUSABLE SERIALIZER (Data Validation Layer)
# ==========================================
class EnquirySerializer(serializers.ModelSerializer):
    """
    Handles validation, serialization (DB to JSON), 
    and deserialization (JSON to DB) for Enquiry data.
    """
    class Meta:
        model = Enquiry
        fields = ['id', 'name', 'email', 'subject', 'message', 'status', 'created_at']
        read_only_fields = ['id', 'created_at']

    def validate_email(self, value):
        """Custom reusable validation rule for email domain safety."""
        parsed_value = value.lower().strip()
        if "disposable-mail" in parsed_value:
            raise serializers.ValidationError("Disposable email domains are prohibited.")
        return parsed_value

# ==========================================
# 2. SCALABLE VIEWSET (Complete CRUD Architecture)
# ==========================================
class EnquiryViewSet(viewsets.ModelViewSet):
    """
    A highly scalable Controller that automatically provides robust implementations 
    for all standard CRUD REST actions:
    
    - Create:  POST   /api/enquiries/
    - Read:    GET    /api/enquiries/     (List all entries)
    - Read:    GET    /api/enquiries/{id}/ (Fetch single entry)
    - Update:  PUT    /api/enquiries/{id}/ (Full update)
    - Update:  PATCH  /api/enquiries/{id}/ (Partial update, e.g., changing status)
    - Delete:  DELETE /api/enquiries/{id}/ (Remove entry)
    """
    queryset = Enquiry.objects.all().order_by('-created_at')
    serializer_class = EnquirySerializer
    
    # SECURITY: Anyone can submit an enquiry (Create), but only authenticated 
    # Admins can Read, Update, or Delete entries.
    permission_classes = [IsAuthenticatedOrReadOnly]

    def create(self, request, *args, **kwargs):
        """Overridden for graceful, clean structured error handling response templates."""
        serializer = self.get_serializer(data=request.data)
        if serializer.is_valid():
            self.perform_create(serializer)
            return Response({
                "status": "success",
                "message": "Enquiry processed successfully.",
                "data": serializer.data
            }, status=status.HTTP_201_CREATED)
            
        return Response({
            "status": "error",
            "message": "Data validation failure.",
            "errors": serializer.errors
        }, status=status.HTTP_400_BAD_REQUEST)




